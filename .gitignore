# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta

# Auto-generated VS / Rider files
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.user
*.userprefs
*.pidb
*.booproj
*.svd

# Rider
.idea/
*.sln.iml

# Unity3D generated meta files for ignored assets
*.pidb.meta
*.booproj.meta
*.svd.meta

# Crash reports
sysinfo.txt

# Build outputs
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.x86
*.x86_64
*.x64
*.zip

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# JetBrains Rider cache
.idea/
